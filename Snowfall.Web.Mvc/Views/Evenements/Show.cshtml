@model Evenement

@{
    ViewBag.Title = Model.Nom;
}

<h1 class="mb-3">@Model.Nom</h1>

<div class="row">
    <div class="col-md-6">
        @if (@Model.ImagePath != null)
        {
            <img class="img-fluid img-thumbnail" src="~/images/evenements/@Model.ImagePath" />
        }
    </div>
    
    <div class="col-md-6">
        <p>@Model.Description</p>
        <p><strong>@Model.Prix$</strong></p>
        <ul class="list-unstyled small">
            <li>Date: @Model.Date.ToShortDateString()</li>
            <li>Capacité: @Model.Capacite places</li>
        </ul>
        
        <span class="badge text-bg-light">@Model.Ville!.Nom, @Model.Ville!.PaysIso</span>
        
        <form asp-controller="Panier" asp-action="Create">
            <input type="hidden" name="itemId" value="@Model.Id" />
            <div class="mb-3">
                <label for="quantite" class="form-label">Quantité</label>
                <input type="number" class="form-control" name="quantite" id="quantite" value="1" min="1" max="@Model.Capacite" />
            </div>
            <button class="btn btn-primary mt-5">Acheter un billet</button>
        </form>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-3">
                <a class="mt-5"
                   asp-controller="Questions"
                   asp-action="New"
                   asp-route-evenementId="@Model.Id">Poser une question aux organisteurs</a>
            </div>
        }
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-3">
                <a class="mt-5"
                   asp-controller="Commentaires"
                   asp-action="New"
                   asp-route-evenementId="@Model.Id">Donnez/Modifiez votre avis sur l'événement!</a>
            </div>
        }
    </div>
    <div class="row mt-5">
        <div class="col-12">
            <h3>Commentaires</h3>
            <hr />
            @foreach (var commentaire in Model.Commentaires ?? [])
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <small class="text-muted">
                            <strong>@commentaire.Utilisateur!.Prenom @commentaire.Utilisateur!.Nom</strong>
                        </small>
                        <p class="card-text">@commentaire.Contenu</p>
                        <small class="text-muted">Le @commentaire.CreatedAt.ToShortDateString()</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>